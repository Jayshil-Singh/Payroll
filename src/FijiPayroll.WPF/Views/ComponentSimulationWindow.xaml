<Window x:Class="FijiPayroll.WPF.Views.ComponentSimulationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fiji BRE - Rule Simulation Panel"
        Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushBgDeep}"
        Foreground="{DynamicResource BrushTextPrimary}">
    <Window.Resources>
        <ResourceDictionary Source="../Styles/FluentStyles.xaml" />
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Payroll Component Simulation" Style="{StaticResource Header1}" />
            <TextBlock Text="Test rules and parameter changes against live employee data without affecting production runs." Style="{StaticResource BodyText}" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="Select Employee:" VerticalAlignment="Center" Margin="0,0,10,0" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}" DisplayMemberPath="FullName" Height="30" />
            <Button Grid.Column="2" Content="Load Data" Command="{Binding LoadEmployeesCommand}" Margin="10,0,0,0" Style="{StaticResource SecondaryButton}" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Expression & Variable input -->
            <DockPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock DockPanel.Dock="Top" Text="Formula Expression Text:" Margin="0,0,0,5" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                <TextBox Text="{Binding ExpressionText, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Height="100" DockPanel.Dock="Top" Margin="0,0,0,10"/>
                
                <TextBlock DockPanel.Dock="Top" Text="Simulation Evaluation Trace Logs:" Margin="0,0,0,5" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                <TextBox Text="{Binding ExecutionLog, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="{DynamicResource BrushBgDeep}" Foreground="{DynamicResource BrushTextPrimary}" FontFamily="Consolas"/>
            </DockPanel>

            <!-- Results display panel -->
            <Border Grid.Column="1" Background="{DynamicResource BrushBgPanel}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Simulation Summary" Style="{StaticResource Header2}" Margin="0,0,0,15"/>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock Text="Original Value" Style="{StaticResource BodyText}" />
                        <TextBlock Text="{Binding OriginalResultValue, StringFormat='FJD {0:N2}'}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,15"/>

                        <TextBlock Text="Simulated Value" Style="{StaticResource BodyText}" />
                        <TextBlock Text="{Binding SimulatedResultValue, StringFormat='FJD {0:N2}'}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrushAccent}" Margin="0,0,0,15"/>

                        <TextBlock Text="Net Variance" Style="{StaticResource BodyText}" />
                        <TextBlock Text="{Binding DifferenceValue, StringFormat='FJD {0:N2}'}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource BrushAlertGreen}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Simulate" Command="{Binding RunSimulationCommand}" Style="{StaticResource ModernButton}" Width="100" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0" Content="Export Comparison PDF" Style="{StaticResource SecondaryButton}" />
            <Button Grid.Column="2" Content="Close" Click="Close_Click" Style="{StaticResource SecondaryButton}" Width="80" />
        </Grid>
    </Grid>
</Window>
