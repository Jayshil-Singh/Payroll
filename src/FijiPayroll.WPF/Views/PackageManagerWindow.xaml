<Window x:Class="FijiPayroll.WPF.Views.PackageManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fiji BRE - Statutory Package Manager"
        Height="550" Width="750"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushBgDeep}"
        Foreground="{DynamicResource BrushTextPrimary}">
    <Window.Resources>
        <ResourceDictionary Source="../Styles/FluentStyles.xaml" />
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Statutory Package Manager" Style="{StaticResource Header1}" />
            <TextBlock Text="Import and verify signed statutory rule packages (e.g. FRCS Tax updates, FNPF Rates)." Style="{StaticResource BodyText}" />
        </StackPanel>

        <!-- Top Section: Package Import / Verify -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Package Folder Path:" Style="{StaticResource BodyText}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding PackagePath, UpdateSourceTrigger=PropertyChanged}" Height="30" />
                    <Button Grid.Column="1" Content="Verify &amp; Import" Command="{Binding ValidatePackageCommand}" Style="{StaticResource ModernButton}" Margin="10,0,0,0"/>
                </Grid>

                <TextBlock Text="Signature Status:" Style="{StaticResource BodyText}" Margin="0,15,0,5" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding SignatureStatus}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrushAccent}" />
            </StackPanel>

            <DockPanel Grid.Column="1">
                <TextBlock DockPanel.Dock="Top" Text="Verification Trace Log:" Style="{StaticResource BodyText}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox Text="{Binding ValidationLogs, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="{DynamicResource BrushBgDeep}" Foreground="{DynamicResource BrushTextPrimary}" FontFamily="Consolas"/>
            </DockPanel>
        </Grid>

        <!-- Bottom Section: Installed Packages -->
        <DockPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock DockPanel.Dock="Top" Text="Installed Statutory Packages:" Style="{StaticResource BodyText}" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <DataGrid ItemsSource="{Binding InstalledPackages}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="{DynamicResource BrushBgPanel}" BorderBrush="{DynamicResource BrushBorder}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Package Name" Binding="{Binding Name}" Width="2*" />
                    <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="*" />
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="3*" />
                    <DataGridTextColumn Header="Signature status" Binding="{Binding SignatureStatus}" Width="1.5*" />
                    <DataGridTextColumn Header="Installed At" Binding="{Binding InstalledAt, StringFormat='yyyy-MM-dd HH:mm'}" Width="1.5*" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <Grid Grid.Row="3">
            <Button Content="Close" Click="Close_Click" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Width="80" />
        </Grid>
    </Grid>
</Window>
