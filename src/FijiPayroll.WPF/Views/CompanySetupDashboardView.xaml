<UserControl x:Class="FijiPayroll.WPF.Views.CompanySetupDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FijiPayroll.WPF.Views"
             xmlns:vm="clr-namespace:FijiPayroll.WPF.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="950"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        
        <Style x:Key="ChecklistIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="{Binding TitleText}" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="#FFFFFF" 
                           FontFamily="Segoe UI Semibold" />
                <TextBlock Text="Complete the wizard steps to configure and lock your tenant environment." 
                           FontSize="14" 
                           Foreground="#A0AEC0" 
                           Margin="0,4,0,0" />
            </StackPanel>

            <Button Grid.Column="1" 
                    Command="{Binding ResetSetupCommand}" 
                    Content="Reset Wizard" 
                    Style="{StaticResource SecondaryButton}" 
                    Width="120" 
                    Height="36" 
                    VerticalAlignment="Center" />
        </Grid>

        <!-- Main Workspace Split Panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: Steps Checklist -->
            <Border Grid.Column="0" Margin="0,0,16,0" CornerRadius="8" Background="#1B2032" BorderBrush="#2E3656" BorderThickness="1" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Onboarding Steps Progress" FontSize="16" Foreground="#FFFFFF" FontWeight="Bold" Margin="0,0,0,16" />

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Tasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#2D3748" BorderThickness="0,0,0,1" Padding="0,12" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Status Icon -->
                                            <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource ChecklistIconStyle}">
                                                        <Setter Property="Text" Value="&#xE71B;"/>
                                                        <Setter Property="Foreground" Value="#718096"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Text" Value="&#xE73E;"/>
                                                                <Setter Property="Foreground" Value="#48BB78"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Step Title & Description -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="13" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#A0AEC0" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                                
                                                <!-- Metadata showing who & when completed -->
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0" Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVisConverter}}">
                                                    <TextBlock Text="By: " FontSize="10" Foreground="#718096"/>
                                                    <TextBlock Text="{Binding CompletedBy}" FontSize="10" Foreground="#718096" Margin="2,0,8,0"/>
                                                    <TextBlock Text="{Binding CompletedUtc, StringFormat='\{0:yyyy-MM-dd HH:mm\}'}" FontSize="10" Foreground="#718096"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- RIGHT PANEL: Action Area for active step -->
            <Border Grid.Column="1" Margin="4,0,0,0" CornerRadius="8" Background="#1B2032" BorderBrush="#2E3656" BorderThickness="1" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header area of Active Step -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Current Step Status" FontSize="14" Foreground="#A0AEC0" FontWeight="SemiBold" />
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Text="{Binding CurrentStep, StringFormat='Step: \{0\}'}" FontSize="24" Foreground="#FFFFFF" FontWeight="Bold" />
                            
                            <Border Grid.Column="1" Background="#2B6CB0" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                <TextBlock Text="Active Wizard Phase" Foreground="#FFFFFF" FontSize="11" FontWeight="Bold" />
                            </Border>
                        </Grid>
                        <Border BorderBrush="#2E3656" BorderThickness="0,0,0,1" Margin="0,16,0,0" />
                    </StackPanel>

                    <!-- Content details -->
                    <Grid Grid.Row="1">
                        <!-- If wizard is complete -->
                        <Grid Visibility="{Binding IsSetupComplete, Converter={StaticResource BoolToVisConverter}}" Margin="0,20">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Width="60" Height="60" CornerRadius="30" Background="#1C4D2C" BorderBrush="#48BB78" BorderThickness="2" HorizontalAlignment="Center" Margin="0,0,0,16">
                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="#48BB78" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Onboarding Completed Successfully" FontSize="20" Foreground="#FFFFFF" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="This tenant environment has been locked and registered." FontSize="14" Foreground="#A0AEC0" HorizontalAlignment="Center" Margin="0,8,0,0" />
                                
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                                    <TextBlock Text="Completed UTC: " FontSize="12" Foreground="#718096" />
                                    <TextBlock Text="{Binding SetupCompletedUtc, StringFormat='\{0:yyyy-MM-dd HH:mm:ss\}'}" FontSize="12" Foreground="#FFFFFF" FontWeight="SemiBold" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Wizard is not complete -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSetupComplete}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            
                            <!-- Validation step specific layout -->
                            <Grid Visibility="{Binding IsValidationStep, Converter={StaticResource BoolToVisConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Dry-Run System Validation" FontSize="16" Foreground="#FFFFFF" FontWeight="Bold" />
                                    <TextBlock Text="Click the button below to run checking rules across all setup steps." FontSize="13" Foreground="#A0AEC0" Margin="0,4,0,16" />
                                    
                                    <Button Command="{Binding ValidateSetupCommand}" 
                                            Content="Run System Check" 
                                            Style="{StaticResource ModernButton}" 
                                            Width="160" 
                                            Height="36" 
                                            HorizontalAlignment="Left" />
                                    
                                    <Border BorderBrush="#2E3656" BorderThickness="0,0,0,1" Margin="0,16,0,16" />
                                </StackPanel>

                                <!-- Validation Lists -->
                                <Grid Grid.Row="1" Visibility="{Binding HasRunValidation, Converter={StaticResource BoolToVisConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Blocking Errors -->
                                    <Grid Grid.Row="0" Margin="0,0,0,12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="Blocking Errors" FontSize="14" Foreground="#FC8181" FontWeight="Bold" />
                                            <Border Background="#C53030" CornerRadius="8" Padding="6,1" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding ValidationErrors.Count}" Foreground="#FFFFFF" FontSize="10" FontWeight="Bold" />
                                            </Border>
                                        </StackPanel>

                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding ValidationErrors}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="&#xE711;" FontFamily="Segoe MDL2 Assets" Foreground="#FC8181" Margin="0,2,8,0" FontSize="12" VerticalAlignment="Top"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding}" Foreground="#F7FAFC" FontSize="12" TextWrapping="Wrap" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>

                                    <!-- Non-Blocking Warnings -->
                                    <Grid Grid.Row="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="Warnings" FontSize="14" Foreground="#FBD38D" FontWeight="Bold" />
                                            <Border Background="#DD6B20" CornerRadius="8" Padding="6,1" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding ValidationWarnings.Count}" Foreground="#FFFFFF" FontSize="10" FontWeight="Bold" />
                                            </Border>
                                        </StackPanel>

                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding ValidationWarnings}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#FBD38D" Margin="0,2,8,0" FontSize="12" VerticalAlignment="Top"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding}" Foreground="#F7FAFC" FontSize="12" TextWrapping="Wrap" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Grid>
                            </Grid>

                            <!-- Non-Validation steps standard actions layout -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsValidationStep}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="Complete this step to advance to the next step of configuration." FontSize="14" Foreground="#A0AEC0" HorizontalAlignment="Center" />
                                    
                                    <Border Margin="0,20,0,0" Padding="20" Background="#121625" CornerRadius="6" BorderBrush="#2D3748" BorderThickness="1">
                                        <TextBlock Text="Use the modular forms in the configuration panels of FEPS to configure details before marking this phase as completed." Foreground="#718096" FontSize="12" HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="300" TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- Footer Action Buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        
                        <!-- Skip Step (only when applicable) -->
                        <Button Command="{Binding SkipStepCommand}" 
                                Content="Skip Phase" 
                                Width="110" 
                                Height="36" 
                                Margin="0,0,12,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CanSkipStep}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Complete Step (for standard phases) -->
                        <Button Command="{Binding CompleteStepCommand}" 
                                Content="Complete Phase" 
                                Width="140" 
                                Height="36">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CanCompleteStep}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Finalize Commit (for validation phase) -->
                        <Button Command="{Binding FinalizeSetupCommand}" 
                                Content="Finalise Onboarding" 
                                Width="170" 
                                Height="36"
                                Background="#319795">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsValidationStep}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
