<UserControl x:Class="FijiPayroll.WPF.Views.LogViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FijiPayroll.WPF.Views"
             xmlns:services="clr-namespace:FijiPayroll.Application.Common.Interfaces;assembly=FijiPayroll.Application"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Action / Filter Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Diagnostics Panel -->
            <RowDefinition Height="Auto"/>
            <!-- Console Content -->
            <RowDefinition Height="*"/>
            <!-- Exception Trace Details -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 1. Page Header ── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="System Diagnostic Logs" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}" FontFamily="Segoe UI Semibold" />
            <TextBlock Text="Monitor runtime health logs, memory footprint buffers, and framework tracing events." FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- ── 2. Filter & Command Bar ── -->
        <Border Grid.Row="1" CornerRadius="6" Background="{DynamicResource BrushBgPanel}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Padding="12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Search input -->
                    <Border CornerRadius="4" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Background="{DynamicResource BrushBgDeep}" Width="300" Height="32" Padding="8,4">
                        <Grid>
                            <TextBlock Text="Search log message or category..." Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center" IsHitTestVisible="False"
                                       Visibility="{Binding SearchText.Length, Converter={StaticResource BoolToVisConverter}, ConverterParameter=invert}"/>
                            <TextBox BorderThickness="0" Background="Transparent" Foreground="{DynamicResource BrushTextPrimary}" CaretBrush="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Border>

                    <!-- Filter by level -->
                    <TextBlock Text="Level:" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center" Margin="16,0,8,0" FontSize="13" FontWeight="SemiBold"/>
                    <ComboBox Height="32" Width="140" ItemsSource="{Binding LogLevels}" SelectedItem="{Binding SelectedLogLevel}" VerticalContentAlignment="Center" Background="{DynamicResource BrushBgDeep}" Foreground="{DynamicResource BrushTextPrimary}">
                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{DynamicResource ColorBgPanel}" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{DynamicResource ColorAccent}" />
                        </ComboBox.Resources>
                    </ComboBox>
                </StackPanel>

                <!-- Action Button -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Clear Buffer" Command="{Binding ClearLogsCommand}" Style="{StaticResource SecondaryButton}" Height="32" Padding="16,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 3. Health Diagnostics Bar ── -->
        <Border Grid.Row="2" CornerRadius="6,6,0,0" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1,1,1,0">
            <Grid Height="38" Background="{DynamicResource BrushBgDeep}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Padding="12,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Live ViewModels: " Foreground="{DynamicResource BrushTextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LiveViewModelCount}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1,0,0,0" Margin="16,4" Height="12" />
                    
                    <TextBlock Text="Memory: " Foreground="{DynamicResource BrushTextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Foreground="{DynamicResource BrushTextPrimary}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} MB / {1} MB limit">
                                <Binding Path="MemoryUsedMb" />
                                <Binding Path="MemoryLimitMb" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1,0,0,0" Margin="16,4" Height="12" />
                    
                    <TextBlock Text="Visible Logs: " Foreground="{DynamicResource BrushTextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding FilteredLogs.Count}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 4. Main Console ListView Grid ── -->
        <Border Grid.Row="3" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Background="{DynamicResource BrushBgPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1" Padding="16,12" Background="{DynamicResource BrushBgDeep}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Timestamp" Foreground="{DynamicResource BrushTextSecondary}" FontWeight="SemiBold" FontSize="12" />
                        <TextBlock Grid.Column="1" Text="Level" Foreground="{DynamicResource BrushTextSecondary}" FontWeight="SemiBold" FontSize="12" />
                        <TextBlock Grid.Column="2" Text="Category" Foreground="{DynamicResource BrushTextSecondary}" FontWeight="SemiBold" FontSize="12" />
                        <TextBlock Grid.Column="3" Text="Message" Foreground="{DynamicResource BrushTextSecondary}" FontWeight="SemiBold" FontSize="12" />
                    </Grid>
                </Border>

                <ListView Grid.Row="1" x:Name="LogListView" ItemsSource="{Binding FilteredLogs}" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Padding" Value="16,10"/>
                            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource BrushBgDeep}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource BrushBgSidebar}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate DataType="{x:Type services:LogEntry}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center" FontSize="12"/>

                                <Border Grid.Column="1" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource BrushBgDeep}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="Information">
                                                    <Setter Property="Background" Value="#EBF8FF"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                    <Setter Property="Background" Value="#FEFCBF"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                    <Setter Property="Background" Value="#FED7D7"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Critical">
                                                    <Setter Property="Background" Value="#FED7D7"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Level}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Level}" Value="Information">
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushAccent}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushAlertOrange}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Error">
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushAlertRed}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Critical">
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushAlertRed}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <TextBlock Grid.Column="2" Text="{Binding Category}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="11" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="3" Text="{Binding Message}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="12"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Selected Log Details Expandable Panel -->
        <Border Grid.Row="4" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8" Background="{DynamicResource BrushBgDeep}" Padding="16">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=LogListView, Path=SelectedItem}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ElementName=LogListView, Path=SelectedItem, Converter={x:Null}}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Diagnostic Context Details" Foreground="{DynamicResource BrushTextSecondary}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <TextBox Text="{Binding ElementName=LogListView, Path=SelectedItem.Exception, Mode=OneWay, TargetNullValue='No exception trace recorded for this log entry.'}" IsReadOnly="True" Background="Transparent" Foreground="#C53030" BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="True" FontFamily="Consolas" FontSize="11"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
