<UserControl x:Class="FijiPayroll.WPF.Views.LogViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FijiPayroll.WPF.Views"
             xmlns:services="clr-namespace:FijiPayroll.WPF.Services"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             Background="Transparent">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <!-- Header Title -->
            <RowDefinition Height="Auto" />
            <!-- Filter Actions Bar -->
            <RowDefinition Height="Auto" />
            <!-- Diagnostics HUD -->
            <RowDefinition Height="Auto" />
            <!-- Logs List Grid -->
            <RowDefinition Height="*" />
            <!-- Active Selected Log Exception trace Details -->
            <RowDefinition Height="Auto" MaxHeight="220" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="System Diagnostics &amp; Audit Logs" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}" FontFamily="Segoe UI Semibold" />
            <TextBlock Text="Real-time internal system trace outputs, database events, and engine execution details." FontSize="14" Foreground="{DynamicResource BrushTextSecondary}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Filters Bar -->
        <Border Grid.Row="1" CornerRadius="6" Background="{DynamicResource BrushBgPanel}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Padding="12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Search Input -->
                    <ColumnDefinition Width="*" />
                    <!-- Checkboxes filters -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- Search Box -->
                    <Border CornerRadius="4" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Background="#0F111A" Width="300" Height="32" Padding="8,4">
                        <Grid>
                            <TextBlock Text="Search log message or category..." Foreground="#4A5568" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=SearchInput, Path=Text}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="SearchInput" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Checkbox Filters -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Info" IsChecked="{Binding ShowInfo}" Foreground="{DynamicResource BrushTextPrimary}" Margin="16,0,0,0" VerticalAlignment="Center"/>
                    <CheckBox Content="Warning" IsChecked="{Binding ShowWarning}" Foreground="{DynamicResource BrushTextPrimary}" Margin="16,0,0,0" VerticalAlignment="Center"/>
                    <CheckBox Content="Error" IsChecked="{Binding ShowError}" Foreground="{DynamicResource BrushTextPrimary}" Margin="16,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Diagnostics HUD -->
        <Border Grid.Row="2" Margin="0,0,0,10" CornerRadius="6"
                Background="#0A0E17" BorderBrush="#1A2540" BorderThickness="1" Padding="12,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Live VMs -->
                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                    <Ellipse Width="8" Height="8" Fill="#4ADE80" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Live ViewModels: " Foreground="#4A5568" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LiveViewModelCount}" Foreground="#A0AEC0" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Memory -->
                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                    <Ellipse Width="8" Height="8" Fill="#60A5FA" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Memory: " Foreground="#4A5568" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Foreground="#A0AEC0" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} MB">
                                <Binding Path="WorkingSetMb"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
                <!-- Log Count -->
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#F59E0B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Visible Logs: " Foreground="#4A5568" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding FilteredLogs.Count}" Foreground="#A0AEC0" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Log List Grid -->
        <Border Grid.Row="3" CornerRadius="8,8,0,0" Background="{DynamicResource BrushBgPanel}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Headers -->
                    <RowDefinition Height="Auto" />
                    <!-- List data -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Grid headers -->
                <Border Grid.Row="0" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1" Padding="16,12" Background="#0A0E17">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Timestamp" Foreground="{DynamicResource BrushTextSecondary}" FontWeight="SemiBold" FontSize="12" />
                        <TextBlock Grid.Column="1" Text="Level" Foreground="{DynamicResource BrushTextSecondary}" FontWeight="SemiBold" FontSize="12" />
                        <TextBlock Grid.Column="2" Text="Category" Foreground="{DynamicResource BrushTextSecondary}" FontWeight="SemiBold" FontSize="12" />
                        <TextBlock Grid.Column="3" Text="Message" Foreground="{DynamicResource BrushTextSecondary}" FontWeight="SemiBold" FontSize="12" />
                    </Grid>
                </Border>

                <!-- Scrollable list of entries -->
                <ListView Grid.Row="1" x:Name="LogListView" ItemsSource="{Binding FilteredLogs}" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Padding" Value="16,10"/>
                            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#171D2F"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#222B45"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate DataType="{x:Type services:LogEntry}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Time -->
                                <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center" FontSize="12"/>

                                <!-- Severity Badge -->
                                <Border Grid.Column="1" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#2A314A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="Information">
                                                    <Setter Property="Background" Value="#102A45"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                    <Setter Property="Background" Value="#452710"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                    <Setter Property="Background" Value="#451010"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Critical">
                                                    <Setter Property="Background" Value="#451010"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Level}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#626D8A"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Level}" Value="Information">
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushAccent}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushAlertOrange}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Error">
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushAlertRed}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Critical">
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushAlertRed}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <!-- Category -->
                                <TextBlock Grid.Column="2" Text="{Binding Category}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="11" FontFamily="Consolas"/>

                                <!-- Message -->
                                <TextBlock Grid.Column="3" Text="{Binding Message}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="12"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Selected Log Details Expandable Panel -->
        <Border Grid.Row="4" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8" Background="#0A0E17" Padding="16">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=LogListView, Path=SelectedItem}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <!-- Only visible when item is selected -->
                        <DataTrigger Binding="{Binding ElementName=LogListView, Path=SelectedItem, Converter={x:Null}}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Diagnostic Context Details" Foreground="{DynamicResource BrushTextSecondary}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <TextBox Text="{Binding ElementName=LogListView, Path=SelectedItem.Exception, Mode=OneWay, TargetNullValue='No exception trace recorded for this log entry.'}" IsReadOnly="True" Background="Transparent" Foreground="#FF9B9B" BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="True" FontFamily="Consolas" FontSize="11"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
