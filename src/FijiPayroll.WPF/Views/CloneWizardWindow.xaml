<Window x:Class="FijiPayroll.WPF.Views.CloneWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fiji BRE - Clone Wizard"
        Height="500" Width="650"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushBackground}"
        Foreground="{DynamicResource BrushTextPrimary}">
    <Window.Resources>
        <ResourceDictionary Source="../Styles/FluentStyles.xaml" />
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Clone Company Components Wizard" Style="{StaticResource Header1}" />
            <TextBlock Text="Copy all payroll components and calculation rules from a source company context to a target company context." Style="{StaticResource BodyText}" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Source Company ID:" Style="{StaticResource BodyText}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox Text="{Binding SourceCompanyId, UpdateSourceTrigger=PropertyChanged}" Height="30" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                <TextBlock Text="Target Company ID:" Style="{StaticResource BodyText}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox Text="{Binding TargetCompanyId, UpdateSourceTrigger=PropertyChanged}" Height="30" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Conflict Resolution Mode:" Style="{StaticResource BodyText}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <ComboBox SelectedValue="{Binding SelectedMode}" SelectedValuePath="Content" Height="30">
                    <ComboBoxItem Content="Merge" />
                    <ComboBoxItem Content="Replace" />
                    <ComboBoxItem Content="Skip" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock DockPanel.Dock="Top" Text="Execution Log &amp; Reconciliation Summary:" Style="{StaticResource BodyText}" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <ListBox ItemsSource="{Binding LogMessages}" Background="#171C2E" Foreground="#32CD32" FontFamily="Consolas" ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </DockPanel>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Run Clone Transaction" Command="{Binding ExecuteCloneCommand}" Style="{StaticResource ModernButton}" Width="160" />
            <Button Grid.Column="2" Content="Close" Click="Close_Click" Style="{StaticResource SecondaryButton}" Width="80" />
        </Grid>
    </Grid>
</Window>
