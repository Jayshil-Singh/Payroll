<Window x:Class="FijiPayroll.WPF.Views.StagedImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fiji BRE - Staged Import Pipeline Dashboard"
        Height="550" Width="750"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushBgDeep}"
        Foreground="{DynamicResource BrushTextPrimary}">
    <Window.Resources>
        <ResourceDictionary Source="../Styles/FluentStyles.xaml" />
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Staged Import Pipeline" Style="{StaticResource Header1}" />
            <TextBlock Text="Load and validate employee records or system master lookup data prior to schema commit." Style="{StaticResource BodyText}" />
        </StackPanel>

        <!-- Top Section: File & Module Choice -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Module selection -->
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Target Staging Module:" Style="{StaticResource BodyText}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <ComboBox ItemsSource="{Binding Modules}" SelectedItem="{Binding SelectedModule}" Height="30" />
            </StackPanel>

            <!-- File path selection -->
            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                <TextBlock Text="Spreadsheet File Path:" Style="{StaticResource BodyText}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseFileCommand}" Style="{StaticResource SecondaryButton}" Margin="5,0,0,0" Height="30"/>
                </Grid>
            </StackPanel>

            <!-- Action button -->
            <Button Grid.Column="2" Content="Validate Staging" Command="{Binding ValidateCommand}" Style="{StaticResource ModernButton}" VerticalAlignment="Bottom" Height="30" Width="130" Margin="0,0,0,0"/>
        </Grid>

        <!-- Middle Section: Staging Metrics & Validation Results -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Session Summary Metrics -->
            <Border Background="{DynamicResource BrushBgPanel}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Session Validation Summary" Style="{StaticResource Header2}" Margin="0,0,0,15"/>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock Text="Total Records Processed:" Style="{StaticResource BodyText}" />
                        <TextBlock Text="{Binding RecordsProcessed}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,15"/>

                        <TextBlock Text="Valid Records (Passed):" Style="{StaticResource BodyText}" />
                        <TextBlock Text="{Binding SuccessCount}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrushAlertGreen}" Margin="0,0,0,15"/>

                        <TextBlock Text="Invalid Records (Failed):" Style="{StaticResource BodyText}" />
                        <TextBlock Text="{Binding FailureCount}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrushAlertRed}" Margin="0,0,0,15"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="{Binding StatusText}" Style="{StaticResource BodyText}" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}"/>
                </Grid>
            </Border>

            <!-- Right Panel: Validation Error Log Grid -->
            <DockPanel Grid.Column="1">
                <TextBlock DockPanel.Dock="Top" Text="Staged Validation Errors:" Style="{StaticResource BodyText}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <DataGrid ItemsSource="{Binding Errors}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="{DynamicResource BrushBgPanel}" BorderBrush="{DynamicResource BrushBorder}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Row" Binding="{Binding Row}" Width="50" />
                        <DataGridTextColumn Header="Column" Binding="{Binding Column}" Width="100" />
                        <DataGridTextColumn Header="Error details" Binding="{Binding ErrorMessage}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>

        <!-- Bottom Actions -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Commit Staging" Command="{Binding CommitCommand}" Style="{StaticResource ModernButton}" Width="200" />
            <Button Grid.Column="2" Content="Close" Click="Close_Click" Style="{StaticResource SecondaryButton}" Width="80" />
        </Grid>
    </Grid>
</Window>
