<UserControl x:Class="FijiPayroll.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FijiPayroll.WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900"
             Background="Transparent">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Executive Dashboard" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#FFFFFF" 
                       FontFamily="Segoe UI Semibold" />
            <TextBlock Text="Fiji Enterprise Payroll System — Operations Overview" 
                       FontSize="14" 
                       Foreground="#A0AEC0" 
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- KPI Widgets Grid -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Card 1: Total Employees -->
            <Border Grid.Column="0" Margin="0,0,8,0" CornerRadius="8" Background="#1B2032" BorderBrush="#2E3656" BorderThickness="1" Padding="16">
                <StackPanel>
                    <TextBlock Text="Total Active Employees" FontSize="12" Foreground="#A0AEC0" FontWeight="SemiBold" />
                    <TextBlock Text="10,482" FontSize="26" Foreground="#FFFFFF" FontWeight="Bold" Margin="0,8,0,0" />
                    <TextBlock Text="+12% this month" FontSize="11" Foreground="#48BB78" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Card 2: Active Run Status -->
            <Border Grid.Column="1" Margin="8,0,8,0" CornerRadius="8" Background="#1B2032" BorderBrush="#2E3656" BorderThickness="1" Padding="16">
                <StackPanel>
                    <TextBlock Text="Current Payroll Cycle" FontSize="12" Foreground="#A0AEC0" FontWeight="SemiBold" />
                    <TextBlock Text="Calculated" FontSize="26" Foreground="#0D99FF" FontWeight="Bold" Margin="0,8,0,0" />
                    <TextBlock Text="Pending approval" FontSize="11" Foreground="#ED8936" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Card 3: Active Allowances/Deductions -->
            <Border Grid.Column="2" Margin="8,0,8,0" CornerRadius="8" Background="#1B2032" BorderBrush="#2E3656" BorderThickness="1" Padding="16">
                <StackPanel>
                    <TextBlock Text="Active Components" FontSize="12" Foreground="#A0AEC0" FontWeight="SemiBold" />
                    <TextBlock Text="48" FontSize="26" Foreground="#FFFFFF" FontWeight="Bold" Margin="0,8,0,0" />
                    <TextBlock Text="2 statutory tables" FontSize="11" Foreground="#A0AEC0" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Card 4: FNPF Contributions Total -->
            <Border Grid.Column="3" Margin="8,0,0,0" CornerRadius="8" Background="#1B2032" BorderBrush="#2E3656" BorderThickness="1" Padding="16">
                <StackPanel>
                    <TextBlock Text="Estimated FNPF Portions" FontSize="12" Foreground="#A0AEC0" FontWeight="SemiBold" />
                    <TextBlock Text="$1.24M" FontSize="26" Foreground="#38B2AC" FontWeight="Bold" Margin="0,8,0,0" />
                    <TextBlock Text="18% total contribution" FontSize="11" Foreground="#38B2AC" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main Dashboard Split Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Chart/Activity Placeholder -->
            <Border Grid.Column="0" Margin="0,0,12,0" CornerRadius="8" Background="#1B2032" BorderBrush="#2E3656" BorderThickness="1" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Monthly Disbursements Analytics" FontSize="16" Foreground="#FFFFFF" FontWeight="Bold" Margin="0,0,0,16" />

                    <!-- Chart Mock Visuals -->
                    <Grid Grid.Row="1" Margin="10,20,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Y-Axis Labels -->
                        <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Stretch" Margin="0,0,12,0">
                            <TextBlock Text="$2.0M" Foreground="#718096" FontSize="10" VerticalAlignment="Top"/>
                            <TextBlock Text="$1.5M" Foreground="#718096" FontSize="10" Margin="0,25,0,0" />
                            <TextBlock Text="$1.0M" Foreground="#718096" FontSize="10" Margin="0,25,0,0" />
                            <TextBlock Text="$0.5M" Foreground="#718096" FontSize="10" Margin="0,25,0,0" />
                            <TextBlock Text="$0.0M" Foreground="#718096" FontSize="10" Margin="0,25,0,0" />
                        </StackPanel>

                        <!-- Bars -->
                        <Grid Grid.Row="0" Grid.Column="1" VerticalAlignment="Bottom" Height="140">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#2E3656" Height="80" Width="40" CornerRadius="4,4,0,0" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                            <Border Grid.Column="1" Background="#2E3656" Height="100" Width="40" CornerRadius="4,4,0,0" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                            <Border Grid.Column="2" Background="#2E3656" Height="90" Width="40" CornerRadius="4,4,0,0" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                            <Border Grid.Column="3" Background="#0D99FF" Height="130" Width="40" CornerRadius="4,4,0,0" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                            <Border Grid.Column="4" Background="#38B2AC" Height="110" Width="40" CornerRadius="4,4,0,0" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- X-Axis Labels -->
                        <Grid Grid.Row="1" Grid.Column="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Jan" Foreground="#718096" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Feb" Foreground="#718096" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Mar" Foreground="#718096" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Apr" Foreground="#718096" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="May" Foreground="#718096" FontSize="11" HorizontalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- Notifications Pane -->
            <Border Grid.Column="1" Margin="12,0,0,0" CornerRadius="8" Background="#1B2032" BorderBrush="#2E3656" BorderThickness="1" Padding="20">
                <StackPanel>
                    <TextBlock Text="System Alerts" FontSize="16" Foreground="#FFFFFF" FontWeight="Bold" Margin="0,0,0,16" />
                    
                    <Border BorderBrush="#2D3748" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="8" Height="8" Fill="#ED8936" Margin="0,4,8,0" VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Pending Approval Run PR-2026-06" FontSize="13" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                <TextBlock Text="Awaiting HR administrator validation" FontSize="11" Foreground="#A0AEC0" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border BorderBrush="#2D3748" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="8" Height="8" Fill="#48BB78" Margin="0,4,8,0" VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Tax Brackets Updated" FontSize="13" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                <TextBlock Text="Standard resident brackets loaded" FontSize="11" Foreground="#A0AEC0" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Padding="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="8" Height="8" Fill="#3182CE" Margin="0,4,8,0" VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="FNPF Exemption Updated" FontSize="13" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                <TextBlock Text="Employee EMP-401 configured" FontSize="11" Foreground="#A0AEC0" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
