<UserControl x:Class="FijiPayroll.WPF.Views.Auth.ESSHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1100"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Pill badge style -->
        <Style x:Key="PillBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Background" Value="#1E3A5F"/>
        </Style>

        <!-- Card style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#1A2035"/>
            <Setter Property="BorderBrush" Value="#2A3555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <!-- KPI card -->
        <Style x:Key="KpiCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <!-- Tab RadioButton style -->
        <Style x:Key="TabBtn" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8A9BBE"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="ESSTab"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4A90D9"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#C8D8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section Label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7EA0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header & KPIs -->
            <RowDefinition Height="Auto"/>
            <!-- Tab bar -->
            <RowDefinition Height="*"/>
            <!-- Tab content -->
        </Grid.RowDefinitions>

        <!-- ═══════════════ HEADER + KPI ROW ═══════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Greeting header -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="{Binding WelcomeMessage}"
                           FontSize="26" FontWeight="Bold" Foreground="#FFFFFF"
                           FontFamily="Segoe UI Semibold"/>
                <TextBlock Text="Your personal payroll &amp; HR portal — view payslips, request leave, and manage your profile."
                           FontSize="13" Foreground="#8A9BBE" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- KPI Cards row -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Leave Balance KPI -->
                <Border Grid.Column="0" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="ANNUAL LEAVE BALANCE" Style="{StaticResource SectionLabel}"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="#48BB78">
                            <TextBlock.Text>
                                <Binding Path="LeaveBalances[0].Available" StringFormat="{}{0:F1} days" FallbackValue="— days"/>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Text="Available to take" FontSize="11" Foreground="#6B7EA0" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Pending Leave KPI -->
                <Border Grid.Column="1" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="PENDING LEAVE REQUESTS" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding LeaveRequests.Count, StringFormat={}{0}}"
                                   FontSize="28" FontWeight="Bold" Foreground="#ED8936"/>
                        <TextBlock Text="Awaiting approval" FontSize="11" Foreground="#6B7EA0" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Active Loans KPI -->
                <Border Grid.Column="2" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="ACTIVE LOANS" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding Loans.Count, StringFormat={}{0}}"
                                   FontSize="28" FontWeight="Bold" Foreground="#4A90D9"/>
                        <TextBlock Text="Loan accounts" FontSize="11" Foreground="#6B7EA0" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Payslips KPI -->
                <Border Grid.Column="3" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="PAYSLIPS AVAILABLE" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding PayslipRuns.Count, StringFormat={}{0}}"
                                   FontSize="28" FontWeight="Bold" Foreground="#38B2AC"/>
                        <TextBlock Text="Posted pay runs" FontSize="11" Foreground="#6B7EA0" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══════════════ TAB BAR ═══════════════ -->
        <Border Grid.Row="1" BorderBrush="#2A3555" BorderThickness="0,0,0,1" Margin="0,0,0,0">
            <StackPanel Orientation="Horizontal">
                <RadioButton Style="{StaticResource TabBtn}" IsChecked="True" Tag="0"
                             Content="&#xE80F;  Dashboard" Checked="Tab_Checked"/>
                <RadioButton Style="{StaticResource TabBtn}" Tag="1"
                             Content="&#xE9F9;  Payslips" Checked="Tab_Checked"/>
                <RadioButton Style="{StaticResource TabBtn}" Tag="2"
                             Content="&#xE8D3;  Leave" Checked="Tab_Checked"/>
                <RadioButton Style="{StaticResource TabBtn}" Tag="3"
                             Content="&#xE8C7;  Loans" Checked="Tab_Checked"/>
                <RadioButton Style="{StaticResource TabBtn}" Tag="4"
                             Content="&#xE77B;  My Profile" Checked="Tab_Checked"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════ TAB CONTENT ═══════════════ -->
        <Grid Grid.Row="2" Margin="0,20,0,0">

            <!-- ── TAB 0: Dashboard ── -->
            <Grid x:Name="TabDashboard" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Leave Balances Summary -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Leave Balance Summary" FontSize="16"
                                   FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,16"/>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding LeaveBalances}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding LeaveTypeName}"
                                                       Foreground="#FFFFFF" FontWeight="SemiBold" FontSize="13"/>
                                            <ProgressBar Value="{Binding Available}" Maximum="{Binding Entitlement}"
                                                         Height="6" Background="#2A3555" Foreground="#48BB78"
                                                         Margin="0,5,20,0" BorderThickness="0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Foreground="#48BB78" FontWeight="Bold" FontSize="16"
                                                       HorizontalAlignment="Right">
                                                <TextBlock.Text>
                                                    <Binding Path="Available" StringFormat="{}{0:F1}"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Foreground="#6B7EA0" FontSize="11" HorizontalAlignment="Right">
                                                <TextBlock.Text>
                                                    <Binding Path="Entitlement" StringFormat="/ {0:F0} days"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Recent Pay &amp; Alerts -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Recent Pay Runs" FontSize="16"
                                   FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,16"/>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding PayslipRuns}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#2A3555" BorderThickness="0,0,0,1"
                                            Padding="0,0,0,10" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding PeriodName}" Foreground="#FFFFFF"
                                                           FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Foreground="#6B7EA0" FontSize="11" Margin="0,2,0,0">
                                                    <TextBlock.Text>
                                                        <Binding Path="PaymentDate" StringFormat="Paid: {0:dd MMM yyyy}"/>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                            <Border Grid.Column="1" Style="{StaticResource PillBadge}">
                                                <TextBlock Text="{Binding Status}" Foreground="#48BB78"
                                                           FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── TAB 1: Payslips ── -->
            <Border x:Name="TabPayslips" Style="{StaticResource Card}" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="My Payslips" FontSize="18" FontWeight="Bold"
                                   Foreground="#FFFFFF" VerticalAlignment="Center"/>
                        <TextBlock Text="Download official payslips for any pay period below."
                                   Foreground="#8A9BBE" FontSize="12" Margin="16,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding PayslipRuns}"
                              SelectedItem="{Binding SelectedPayslipRun}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="Transparent" RowBackground="#1A2035"
                              AlternatingRowBackground="#1E2540"
                              BorderThickness="0" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#2A3555"
                              HeadersVisibility="Column"
                              Foreground="#C8D8F0" FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Pay Period" Binding="{Binding PeriodName}" Width="*"/>
                            <DataGridTextColumn Header="Frequency" Binding="{Binding Frequency}" Width="120"/>
                            <DataGridTextColumn Header="Payment Date" Binding="{Binding PaymentDate, StringFormat=dd MMM yyyy}" Width="130"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            <DataGridTemplateColumn Header="Download" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="&#xE74E; PDF"
                                                Command="{Binding DataContext.DownloadPayslipCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="#1E3A5F" Foreground="#4A90D9"
                                                BorderThickness="0" Padding="8,4"
                                                Cursor="Hand" FontSize="11" FontWeight="Bold"
                                                FontFamily="Segoe MDL2 Assets, Segoe UI"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ── TAB 2: Leave ── -->
            <Grid x:Name="TabLeave" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <!-- Leave history list -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Leave Request History" FontSize="16"
                                   FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,16"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding LeaveRequests}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" RowBackground="#1A2035"
                                  AlternatingRowBackground="#1E2540"
                                  BorderThickness="0" GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#2A3555"
                                  Foreground="#C8D8F0" FontSize="12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Leave Type" Binding="{Binding LeaveTypeName}" Width="*"/>
                                <DataGridTextColumn Header="Start" Binding="{Binding StartDate, StringFormat=dd MMM yyyy}" Width="110"/>
                                <DataGridTextColumn Header="End" Binding="{Binding EndDate, StringFormat=dd MMM yyyy}" Width="110"/>
                                <DataGridTextColumn Header="Days" Binding="{Binding TotalDays, StringFormat={}{0:F1}}" Width="60"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Submit leave form -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Request Leave" FontSize="16" FontWeight="Bold"
                                   Foreground="#FFFFFF" Margin="0,0,0,20"/>

                        <TextBlock Text="LEAVE TYPE" Style="{StaticResource SectionLabel}"/>
                        <ComboBox ItemsSource="{Binding LeaveTypes}"
                                  SelectedItem="{Binding SelectedLeaveType}"
                                  DisplayMemberPath="TypeName"
                                  Background="#0F1525" Foreground="#C8D8F0"
                                  BorderBrush="#2A3555" Padding="8" Margin="0,0,0,14"/>

                        <TextBlock Text="START DATE" Style="{StaticResource SectionLabel}"/>
                        <DatePicker SelectedDate="{Binding LeaveStartDate}"
                                    Background="#0F1525" Foreground="#C8D8F0"
                                    BorderBrush="#2A3555" Margin="0,0,0,14"/>

                        <TextBlock Text="END DATE" Style="{StaticResource SectionLabel}"/>
                        <DatePicker SelectedDate="{Binding LeaveEndDate}"
                                    Background="#0F1525" Foreground="#C8D8F0"
                                    BorderBrush="#2A3555" Margin="0,0,0,14"/>

                        <TextBlock Text="TOTAL WORKING DAYS" Style="{StaticResource SectionLabel}"/>
                        <TextBox Text="{Binding LeaveTotalDays, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#0F1525" Foreground="#C8D8F0"
                                 BorderBrush="#2A3555" Padding="8,6" Margin="0,0,0,14"/>

                        <TextBlock Text="REASON / NOTES" Style="{StaticResource SectionLabel}"/>
                        <TextBox Text="{Binding LeaveNotes, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#0F1525" Foreground="#C8D8F0"
                                 BorderBrush="#2A3555" Padding="8,6"
                                 Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                 Margin="0,0,0,20"/>

                        <Button Content="Submit Leave Request"
                                Command="{Binding SubmitLeaveRequestCommand}"
                                Background="#1E6F3A" Foreground="#FFFFFF"
                                BorderThickness="0" Padding="12,8"
                                Cursor="Hand" FontWeight="SemiBold" FontSize="13"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── TAB 3: Loans ── -->
            <Border x:Name="TabLoans" Style="{StaticResource Card}" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="My Loan Accounts" FontSize="18"
                               FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,16"/>
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Loans}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding LoanDescription}"
                                                       Foreground="#FFFFFF" FontWeight="Bold" FontSize="14"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBlock Text="Principal: " Foreground="#6B7EA0" FontSize="12"/>
                                                <TextBlock Foreground="#C8D8F0" FontSize="12">
                                                    <TextBlock.Text>
                                                        <Binding Path="PrincipalAmount" StringFormat="{}{0:C}"/>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock Text="  |  Deduction: " Foreground="#6B7EA0" FontSize="12"/>
                                                <TextBlock Foreground="#C8D8F0" FontSize="12">
                                                    <TextBlock.Text>
                                                        <Binding Path="DeductionAmountPerPeriod" StringFormat="{}{0:C}/period"/>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="Remaining Balance" Foreground="#6B7EA0"
                                                       FontSize="11" HorizontalAlignment="Right"/>
                                            <TextBlock Foreground="#ED8936" FontWeight="Bold"
                                                       FontSize="20" HorizontalAlignment="Right">
                                                <TextBlock.Text>
                                                    <Binding Path="RemainingBalance" StringFormat="{}{0:C}"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <Border Style="{StaticResource PillBadge}" HorizontalAlignment="Right" Margin="0,6,0,0">
                                                <TextBlock Text="{Binding Status}" Foreground="#4A90D9"
                                                           FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- ── TAB 4: Profile ── -->
            <Border x:Name="TabProfile" Style="{StaticResource Card}" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Personal Details -->
                    <StackPanel Grid.Column="0">
                        <!-- Avatar circle -->
                        <Border Width="72" Height="72" CornerRadius="36" Background="#1E3A5F"
                                HorizontalAlignment="Left" Margin="0,0,0,16">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="34"
                                       Foreground="#4A90D9" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="FULL NAME" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding EmployeeProfile.FullName, FallbackValue='—'}"
                                   Foreground="#FFFFFF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>

                        <TextBlock Text="DEPARTMENT" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding EmployeeProfile.Department, FallbackValue='—'}"
                                   Foreground="#C8D8F0" FontSize="13" Margin="0,0,0,12"/>

                        <TextBlock Text="POSITION" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding EmployeeProfile.Position, FallbackValue='—'}"
                                   Foreground="#C8D8F0" FontSize="13" Margin="0,0,0,12"/>

                        <TextBlock Text="EMPLOYEE CODE" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding EmployeeProfile.EmployeeCode, FallbackValue='—'}"
                                   Foreground="#C8D8F0" FontSize="13" Margin="0,0,0,12"/>

                        <TextBlock Text="EMAIL" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding EmployeeProfile.Email, FallbackValue='—'}"
                                   Foreground="#C8D8F0" FontSize="13"/>
                    </StackPanel>

                    <!-- Right: Statutory Details -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Statutory &amp; Payroll Details" FontSize="16"
                                   FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,16"/>

                        <TextBlock Text="TIN" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding EmployeeProfile.Tin, FallbackValue='—'}"
                                   Foreground="#C8D8F0" FontSize="13" Margin="0,0,0,12"/>

                        <TextBlock Text="FNPF NUMBER" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding EmployeeProfile.FnpfNumber, FallbackValue='—'}"
                                   Foreground="#C8D8F0" FontSize="13" Margin="0,0,0,12"/>

                        <TextBlock Text="RESIDENCY STATUS" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding EmployeeProfile.ResidencyStatus, FallbackValue='—'}"
                                   Foreground="#C8D8F0" FontSize="13" Margin="0,0,0,12"/>

                        <TextBlock Text="PAY FREQUENCY" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding EmployeeProfile.Frequency, FallbackValue='—'}"
                                   Foreground="#C8D8F0" FontSize="13" Margin="0,0,0,12"/>

                        <TextBlock Text="COST CENTRE" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding EmployeeProfile.CostCentre, FallbackValue='—'}"
                                   Foreground="#C8D8F0" FontSize="13"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
