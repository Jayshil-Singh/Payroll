<UserControl x:Class="FijiPayroll.WPF.Views.PendingApprovalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FijiPayroll.WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1024"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Action / Filter Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Content Grid split -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── 1. Page Header ── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Pending Change Requests" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}" FontFamily="Segoe UI Semibold" />
            <TextBlock Text="Review, execute approvals, or perform bulk validation for master data and payroll calculation requests." FontSize="14" Foreground="{DynamicResource BrushTextSecondary}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- ── 2. Action & Filter Bar ── -->
        <Border Grid.Row="1" CornerRadius="6" Background="{DynamicResource BrushBgPanel}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Padding="12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Search Input Box -->
                    <Border CornerRadius="4" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Background="{DynamicResource BrushBgDeep}" Width="280" Height="32" Padding="8,4">
                        <Grid>
                            <TextBlock Text="Search by Entity ID or Requester..." 
                                       Foreground="{DynamicResource BrushTextSecondary}" 
                                       VerticalAlignment="Center" 
                                       IsHitTestVisible="False" 
                                       Visibility="{Binding SearchText.Length, Converter={StaticResource BoolToVisConverter}, ConverterParameter=invert}"/>
                            <TextBox BorderThickness="0" 
                                     Background="Transparent" 
                                     Foreground="{DynamicResource BrushTextPrimary}" 
                                     CaretBrush="{DynamicResource BrushTextPrimary}"
                                     VerticalAlignment="Center"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Border>

                    <!-- Filter ComboBox -->
                    <TextBlock Text="Type:" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center" Margin="16,0,8,0" FontSize="13" FontWeight="SemiBold"/>
                    <ComboBox Height="32" Width="140" 
                              ItemsSource="{Binding EntityTypeFilters}" 
                              SelectedItem="{Binding SelectedEntityTypeFilter}"
                              VerticalContentAlignment="Center" 
                              Background="{DynamicResource BrushBgDeep}" 
                              Foreground="{DynamicResource BrushTextPrimary}" 
                              BorderBrush="{DynamicResource BrushBorder}" 
                              BorderThickness="1">
                        <ComboBox.Resources>
                            <!-- Override popup colors for modern styling -->
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{DynamicResource ColorBgPanel}" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="{DynamicResource ColorTextPrimary}" />
                        </ComboBox.Resources>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- Bulk Approve button -->
                    <Button Content="Bulk Approve Selected" 
                            Command="{Binding BulkApproveCommand}" 
                            Style="{StaticResource SecondaryButton}" 
                            FontWeight="SemiBold"
                            Height="32" 
                            Padding="16,0" 
                            Margin="0,0,12,0" />

                    <!-- Refresh button -->
                    <Button Content="Refresh" 
                            Command="{Binding LoadWorkflowsCommand}" 
                            Style="{StaticResource ModernButton}" 
                            FontWeight="SemiBold" 
                            Height="32" 
                            Padding="16,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 3. Content Splits ── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: DataGrid Table -->
            <Border Grid.Column="0" Margin="0,0,16,0" CornerRadius="8" Background="{DynamicResource BrushBgPanel}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Padding="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid ItemsSource="{Binding FilteredWorkflows}" 
                              SelectedItem="{Binding SelectedWorkflowItem}"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              HeadersVisibility="Column" 
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0" 
                              Background="Transparent"
                              RowHeight="42"
                              ColumnHeaderHeight="40"
                              SelectionMode="Single"
                              CanUserAddRows="False"
                              Foreground="{DynamicResource BrushTextPrimary}">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#171C2E"/>
                                <Setter Property="Foreground" Value="#A0AEC0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#252C42"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2B3654"/>
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <!-- Checkbox for Bulk Selection -->
                            <DataGridTemplateColumn Width="45">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Entity Type -->
                            <DataGridTextColumn Header="Module" Binding="{Binding Workflow.EntityType}" Width="110"/>

                            <!-- Entity ID -->
                            <DataGridTextColumn Header="Entity ID" Binding="{Binding Workflow.EntityId}" Width="*"/>

                            <!-- Initiated By -->
                            <DataGridTextColumn Header="Requester" Binding="{Binding Workflow.RequestedBy}" Width="150"/>

                            <!-- Created Date -->
                            <DataGridTextColumn Header="Date Requested" Binding="{Binding Workflow.CreatedDate, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="140"/>

                            <!-- State Badge -->
                            <DataGridTemplateColumn Header="State" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Background="#2A314A">
                                            <TextBlock Text="{Binding Workflow.CurrentState}" FontSize="11" FontWeight="SemiBold" Foreground="#ED8936"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state display -->
                    <TextBlock Text="No pending approval requests match current filters." 
                               Style="{StaticResource BodyText}" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding FilteredWorkflows.Count, Converter={StaticResource BoolToVisConverter}, ConverterParameter=invert}" />
                </Grid>
            </Border>

            <!-- RIGHT PANEL: Action Review & History timeline -->
            <Border Grid.Column="1" Background="{DynamicResource BrushBgPanel}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- If no workflow is selected -->
                            <StackPanel Visibility="{Binding SelectedWorkflow, Converter={StaticResource BoolToVisConverter}, ConverterParameter=invert}" Height="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE73A;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#4A5568" HorizontalAlignment="Center" Margin="0,100,0,16"/>
                                <TextBlock Text="Select a Request" Style="{StaticResource Header2}" Foreground="#718096" HorizontalAlignment="Center" />
                                <TextBlock Text="Select an entry from the table to review details, view audit steps, and execute approval commands." 
                                           Style="{StaticResource BodyText}" TextAlignment="Center" MaxWidth="260" Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- If a workflow is selected -->
                            <StackPanel Visibility="{Binding SelectedWorkflow, Converter={StaticResource BoolToVisConverter}}">
                                <!-- Details Title -->
                                <TextBlock Text="Review Change Request" Style="{StaticResource Header2}" Margin="0,0,0,16"/>

                                <!-- Detail Fields -->
                                <Border Background="{DynamicResource BrushBgDeep}" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Module:" Foreground="{DynamicResource BrushTextSecondary}" FontSize="12" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedWorkflow.EntityType}" Foreground="{DynamicResource BrushTextPrimary}" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Entity ID:" Foreground="{DynamicResource BrushTextSecondary}" FontSize="12" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedWorkflow.EntityId}" Foreground="{DynamicResource BrushAccent}" FontWeight="Bold" FontSize="13" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Requested By:" Foreground="{DynamicResource BrushTextSecondary}" FontSize="12" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedWorkflow.RequestedBy}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="13" Margin="0,4,0,4"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Approver Role:" Foreground="{DynamicResource BrushTextSecondary}" FontSize="12" Margin="0,4,0,4"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedWorkflow.CurrentApproverRole}" Foreground="{DynamicResource BrushAlertOrange}" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,4"/>
                                    </Grid>
                                </Border>

                                <!-- Comments TextBox -->
                                <TextBlock Text="Decision Comments" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Comments, UpdateSourceTrigger=PropertyChanged}" 
                                         Height="80" 
                                         AcceptsReturn="True" 
                                         TextWrapping="Wrap" 
                                         Background="{DynamicResource BrushBgDeep}" 
                                         BorderBrush="{DynamicResource BrushBorder}" 
                                         Foreground="{DynamicResource BrushTextPrimary}" 
                                         CaretBrush="{DynamicResource BrushTextPrimary}" 
                                         Padding="8" 
                                         Margin="0,0,0,16"/>

                                <!-- Approve & Reject Actions -->
                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Reject Action Button -->
                                    <Button Grid.Column="0" 
                                            Content="Reject Request" 
                                            Command="{Binding RejectCommand}"
                                            Height="38" 
                                            Margin="0,0,8,0"
                                            Background="#E53E3E" 
                                            Foreground="White" 
                                            FontWeight="Bold" 
                                            BorderThickness="0" 
                                            Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>

                                    <!-- Approve Action Button -->
                                    <Button Grid.Column="1" 
                                            Content="Approve Request" 
                                            Command="{Binding ApproveCommand}"
                                            Height="38" 
                                            Margin="8,0,0,0"
                                            Background="#38A169" 
                                            Foreground="White" 
                                            FontWeight="Bold" 
                                            BorderThickness="0" 
                                            Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>

                                <!-- Workflow Steps Timeline -->
                                <TextBlock Text="Workflow Execution Timeline" FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,12"/>
                                <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                                    <ItemsControl ItemsSource="{Binding WorkflowSteps}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <!-- Timeline node dot -->
                                                    <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#0D99FF" Margin="4,4,12,0" VerticalAlignment="Top"/>
                                                    
                                                    <!-- Step detail text -->
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Foreground="#FFFFFF" FontWeight="SemiBold" FontSize="12">
                                                            <Run Text="{Binding FromState}" Foreground="#A0AEC0"/>
                                                            <Run Text=" ➔ " Foreground="#718096"/>
                                                            <Run Text="{Binding ToState}" Foreground="#ED8936"/>
                                                        </TextBlock>
                                                        <TextBlock Foreground="#718096" FontSize="11" Margin="0,2,0,2">
                                                            <Run Text="By: "/>
                                                            <Run Text="{Binding TransitionedBy}" Foreground="#FFFFFF"/>
                                                            <Run Text=" | "/>
                                                            <Run Text="{Binding TransitionedAt, StringFormat=\{0:dd/MM/yyyy HH:mm:ss\}}"/>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Comments}" Foreground="#A0AEC0" FontSize="12" Margin="0,2,0,0" FontStyle="Italic" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
