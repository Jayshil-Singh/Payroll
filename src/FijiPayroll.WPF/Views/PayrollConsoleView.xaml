<UserControl x:Class="FijiPayroll.WPF.Views.PayrollConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FijiPayroll.WPF.Views"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:enums="clr-namespace:FijiPayroll.Domain.Enumerations;assembly=FijiPayroll.Domain"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/FluentStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />

            <ObjectDataProvider x:Key="FrequencyEnumValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="enums:PayrollFrequencyType" />
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>

            <ObjectDataProvider x:Key="AdjustmentEnumValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="enums:PayrollAdjustmentType" />
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Enterprise Payroll Processing Platform" Style="{StaticResource Header1}" />
            <TextBlock Text="Manage payroll frequencies, periods, groups, double-entry ledger verification, and high performance batch calculations." Style="{StaticResource BodyText}" />
        </StackPanel>

        <!-- Main Tab Control -->
        <TabControl Grid.Row="1" Background="{DynamicResource BrushBgPanel}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1">
            
            <!-- TABS 1: OVERVIEW -->
            <TabItem Header="Overview" Width="100" Height="30">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1D243B" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Processing Parameters" Style="{StaticResource Header2}" Margin="0,0,0,15"/>
                            
                            <TextBlock Text="Target Company ID:" Style="{StaticResource BodyText}" Margin="0,5,0,2" />
                            <TextBox Text="{Binding CompanyId}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>

                            <TextBlock Text="Active Payroll Run ID:" Style="{StaticResource BodyText}" Margin="0,15,0,2" />
                            <TextBox Text="{Binding SelectedRunId}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>

                            <Button Content="Load Ledger &amp; Exceptions" Command="{Binding LoadLedgerCommand}" Margin="0,20,0,0" Height="35" Style="{StaticResource ModernButton}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#1D243B" CornerRadius="8" Padding="20" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Fiji Compliance Core" Style="{StaticResource Header2}" Margin="0,0,0,15"/>
                            <TextBlock Text="This console provides end-to-end management of Fiji statutory reporting, voluntary deductions, and double-entry auditing." Style="{StaticResource BodyText}" TextWrapping="Wrap" />
                            
                            <StackPanel Margin="0,20,0,0">
                                <TextBlock Text="Tax Tables: Fiji Resident &amp; Non-Resident 2025-2026" Foreground="{DynamicResource BrushTextPrimary}" FontWeight="SemiBold" Margin="0,5,0,5" />
                                <TextBlock Text="FNPF Rates: 8% Employee / 10% Employer" Foreground="{DynamicResource BrushTextPrimary}" FontWeight="SemiBold" Margin="0,5,0,5" />
                                <TextBlock Text="Auditing: Cryptographic immutable records with SHA-256 validation" Foreground="{DynamicResource BrushTextPrimary}" FontWeight="SemiBold" Margin="0,5,0,5" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TABS 2: PERIOD MANAGER -->
            <TabItem Header="Period Manager" Width="110" Height="30">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock DockPanel.Dock="Top" Text="Active Payroll Periods" Style="{StaticResource Header2}" Margin="0,0,0,10"/>
                        <DataGrid ItemsSource="{Binding Periods}" SelectedItem="{Binding SelectedPeriod}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="#181D30" BorderBrush="{DynamicResource BrushBorder}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                                <DataGridTextColumn Header="Code" Binding="{Binding PeriodCode}" Width="100" />
                                <DataGridTextColumn Header="Frequency" Binding="{Binding PayrollFrequency}" Width="100" />
                                <DataGridTextColumn Header="Start Date" Binding="{Binding StartDate, StringFormat=yyyy-MM-dd}" Width="110" />
                                <DataGridTextColumn Header="End Date" Binding="{Binding EndDate, StringFormat=yyyy-MM-dd}" Width="110" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <Border Grid.Column="1" Background="#1D243B" CornerRadius="8" Padding="15">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Create New Period" Style="{StaticResource Header2}" Margin="0,0,0,10"/>
                                
                                <TextBlock Text="Period Code (e.g. 2026-W24):" Style="{StaticResource BodyText}" Margin="0,5,0,2"/>
                                <TextBox Text="{Binding NewPeriodCode}" Height="28"/>

                                <TextBlock Text="Frequency:" Style="{StaticResource BodyText}" Margin="0,10,0,2"/>
                                <ComboBox SelectedItem="{Binding NewPeriodFrequency}" ItemsSource="{Binding Source={StaticResource FrequencyEnumValues}}" Height="28"/>

                                <TextBlock Text="Start Date:" Style="{StaticResource BodyText}" Margin="0,10,0,2"/>
                                <DatePicker SelectedDate="{Binding NewStartDate}" Height="28"/>

                                <TextBlock Text="End Date:" Style="{StaticResource BodyText}" Margin="0,10,0,2"/>
                                <DatePicker SelectedDate="{Binding NewEndDate}" Height="28"/>

                                <Button Content="Create Period" Command="{Binding CreatePeriodCommand}" Margin="0,15,0,0" Style="{StaticResource ModernButton}"/>
                                
                                <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0" Margin="0,15,0,15" />

                                <TextBlock Text="Selected Period Actions" Style="{StaticResource Header2}" Margin="0,0,0,10"/>
                                <Button Content="Close Selected Period" Command="{Binding ClosePeriodCommand}" Margin="0,5,0,5" Style="{StaticResource SecondaryButton}"/>
                                <Button Content="Lock Selected Period" Command="{Binding LockPeriodCommand}" Margin="0,5,0,5" Style="{StaticResource SecondaryButton}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TABS 3: PAYROLL GROUPS -->
            <TabItem Header="Payroll Groups" Width="100" Height="30">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock DockPanel.Dock="Top" Text="Registered Payroll Groups" Style="{StaticResource Header2}" Margin="0,0,0,10"/>
                        <DataGrid ItemsSource="{Binding Groups}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="#181D30" BorderBrush="{DynamicResource BrushBorder}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150" />
                                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="100" />
                                <DataGridTextColumn Header="Cost Centre" Binding="{Binding DefaultCostCentre}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <Border Grid.Column="1" Background="#1D243B" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Create New Group" Style="{StaticResource Header2}" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Group Name:" Style="{StaticResource BodyText}" Margin="0,5,0,2"/>
                            <TextBox Text="{Binding NewGroupName}" Height="28"/>

                            <TextBlock Text="Group Code:" Style="{StaticResource BodyText}" Margin="0,10,0,2"/>
                            <TextBox Text="{Binding NewGroupCode}" Height="28"/>

                            <Button Content="Create Group" Command="{Binding CreateGroupCommand}" Margin="0,15,0,0" Style="{StaticResource ModernButton}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TABS 4: ADJUSTMENTS -->
            <TabItem Header="Adjustments" Width="95" Height="30">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1D243B" CornerRadius="8" Padding="20" HorizontalAlignment="Center" Width="400">
                        <StackPanel>
                            <TextBlock Text="Stage Manual Adjustment" Style="{StaticResource Header2}" Margin="0,0,0,15"/>

                            <TextBlock Text="Employee ID:" Style="{StaticResource BodyText}" Margin="0,5,0,2" />
                            <TextBox Text="{Binding AdjEmployeeId}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>

                            <TextBlock Text="Adjustment Type:" Style="{StaticResource BodyText}" Margin="0,10,0,2" />
                            <ComboBox SelectedItem="{Binding AdjType}" ItemsSource="{Binding Source={StaticResource AdjustmentEnumValues}}" Height="30"/>

                            <TextBlock Text="Amount:" Style="{StaticResource BodyText}" Margin="0,10,0,2" />
                            <TextBox Text="{Binding AdjAmount}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>

                            <TextBlock Text="Description:" Style="{StaticResource BodyText}" Margin="0,10,0,2" />
                            <TextBox Text="{Binding AdjDescription}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>

                            <Button Content="Stage Adjustment" Command="{Binding StageAdjustmentCommand}" Margin="0,20,0,0" Height="35" Style="{StaticResource ModernButton}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#1D243B" CornerRadius="8" Padding="20" Margin="15,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Adjustment Instructions" Style="{StaticResource Header2}" Margin="0,0,0,10"/>
                            <TextBlock Style="{StaticResource BodyText}" TextWrapping="Wrap">
                                Stage manual adjustments for employees before triggering the batch run. Earnings and allowances are added to the gross, and deductions are subtracted from net pay. Non-statutory voluntary deductions will be checked against the Voluntary Deduction Policy.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TABS 5: BATCH MONITOR -->
            <TabItem Header="Batch Monitor" Width="100" Height="30">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1D243B" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Batch Calculations" Style="{StaticResource Header2}" Margin="0,0,0,20"/>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Status:" Style="{StaticResource BodyText}"/>
                                    <TextBlock Text="{Binding BatchStatusText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Elapsed Time:" Style="{StaticResource BodyText}"/>
                                    <TextBlock Text="{Binding ElapsedTimeText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Overall Progress:" Style="{StaticResource BodyText}" Margin="0,0,0,5"/>
                            <ProgressBar Value="{Binding BatchProgress}" Height="25" Foreground="{DynamicResource BrushAccent}" Background="#111524"/>
                            <TextBlock Text="{Binding BatchProgress, StringFormat={}{0:0.0}%}" HorizontalAlignment="Right" Style="{StaticResource BodyText}" Margin="0,5,0,15"/>

                            <UniformGrid Columns="2" Margin="0,10,0,0">
                                <Button Content="Run Batch" Command="{Binding StartBatchCommand}" Height="35" Style="{StaticResource ModernButton}" Margin="5"/>
                                <Button Content="Cancel" Command="{Binding CancelBatchCommand}" Height="35" Style="{StaticResource SecondaryButton}" Margin="5"/>
                            </UniformGrid>
                            <UniformGrid Columns="2" Margin="0,5,0,0">
                                <Button Content="Pause" Command="{Binding PauseBatchCommand}" Height="35" Style="{StaticResource SecondaryButton}" Margin="5"/>
                                <Button Content="Resume" Command="{Binding ResumeBatchCommand}" Height="35" Style="{StaticResource SecondaryButton}" Margin="5"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#1D243B" CornerRadius="8" Padding="20" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Performance Benchmark Specs" Style="{StaticResource Header2}" Margin="0,0,0,15"/>
                            <TextBlock Text="Batch processing is engineered utilizing TPL Dataflow for high-throughput concurrency." Style="{StaticResource BodyText}" TextWrapping="Wrap"/>
                            <TextBlock Text="Target: 10,000 Employees calculated in &lt; 60 seconds." Style="{StaticResource BodyText}" FontWeight="Bold" Margin="0,10,0,10" Foreground="{DynamicResource BrushAccent}"/>
                            <TextBlock Text="UI Thread Guarantee: Calculation runs entirely in background threads without blocking WPF Dispatcher queues." Style="{StaticResource BodyText}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TABS 6: EXCEPTIONS -->
            <TabItem Header="Exceptions" Width="85" Height="30">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock DockPanel.Dock="Top" Text="Calculations Exception Queue" Style="{StaticResource Header2}" Margin="0,0,0,10"/>
                        <DataGrid ItemsSource="{Binding Exceptions}" SelectedItem="{Binding SelectedException}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="#181D30" BorderBrush="{DynamicResource BrushBorder}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Emp ID" Binding="{Binding EmployeeId}" Width="60" />
                                <DataGridTextColumn Header="Name" Binding="{Binding EmployeeName}" Width="120" />
                                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="80" />
                                <DataGridTextColumn Header="Failure Reason" Binding="{Binding Reason}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <Border Grid.Column="1" Background="#1D243B" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Resolve Exception" Style="{StaticResource Header2}" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Employee:" Style="{StaticResource BodyText}"/>
                            <TextBlock Text="{Binding SelectedException.EmployeeName}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"/>

                            <TextBlock Text="Recommendation:" Style="{StaticResource BodyText}"/>
                            <TextBlock Text="{Binding SelectedException.Recommendation}" TextWrapping="Wrap" Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,15"/>

                            <TextBlock Text="Resolution Statement:" Style="{StaticResource BodyText}" Margin="0,5,0,2"/>
                            <TextBox Text="{Binding ResolutionText}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="5"/>

                            <Button Content="Submit Resolution" Command="{Binding ResolveExceptionCommand}" Margin="0,15,0,0" Style="{StaticResource ModernButton}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TABS 7: LEDGER EXPLORER -->
            <TabItem Header="Ledger Explorer" Width="110" Height="30">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1D243B" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Total Gross:" Style="{StaticResource BodyText}"/>
                                <TextBlock Text="{Binding ActiveLedger.TotalGross, StringFormat={}{0:C}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Total PAYE:" Style="{StaticResource BodyText}"/>
                                <TextBlock Text="{Binding ActiveLedger.TotalPAYE, StringFormat={}{0:C}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Total Net Pay:" Style="{StaticResource BodyText}"/>
                                <TextBlock Text="{Binding ActiveLedger.TotalNetPay, StringFormat={}{0:C}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Ledger Integrity Hash:" Style="{StaticResource BodyText}"/>
                                <TextBlock Text="{Binding ActiveLedger.Hash}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock DockPanel.Dock="Top" Text="Employee Summaries" Style="{StaticResource BodyText}" FontWeight="Bold" Margin="0,0,0,5"/>
                            <DataGrid ItemsSource="{Binding LedgerEmployees}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="#181D30" BorderBrush="{DynamicResource BrushBorder}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Emp ID" Binding="{Binding EmployeeId}" Width="60" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding EmployeeName}" Width="120" />
                                    <DataGridTextColumn Header="Gross" Binding="{Binding Gross, StringFormat={}{0:C}}" Width="90" />
                                    <DataGridTextColumn Header="Net" Binding="{Binding NetPay, StringFormat={}{0:C}}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>

                        <DockPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock DockPanel.Dock="Top" Text="Double-Entry Transactions" Style="{StaticResource BodyText}" FontWeight="Bold" Margin="0,0,0,5"/>
                            <DataGrid ItemsSource="{Binding LedgerTransactions}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="#181D30" BorderBrush="{DynamicResource BrushBorder}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Account" Binding="{Binding AccountCode}" Width="80" />
                                    <DataGridTextColumn Header="Debit" Binding="{Binding Debit, StringFormat={}{0:C}}" Width="90" />
                                    <DataGridTextColumn Header="Credit" Binding="{Binding Credit, StringFormat={}{0:C}}" Width="90" />
                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TABS 8: DIFFERENCE EXPLORER -->
            <TabItem Header="Difference Explorer" Width="130" Height="30">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1D243B" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Run A ID (Base Run):" Style="{StaticResource BodyText}"/>
                                <TextBox Text="{Binding CompareRunAId}" Height="28" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,15,0">
                                <TextBlock Text="Run B ID (Comparison Run):" Style="{StaticResource BodyText}"/>
                                <TextBox Text="{Binding CompareRunBId}" Height="28" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Compare Runs" Command="{Binding CompareRunsCommand}" Width="120" Height="30" VerticalAlignment="Bottom" Style="{StaticResource ModernButton}"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#1D243B" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Financial Deltas" Style="{StaticResource Header2}" Margin="0,0,0,15"/>
                                
                                <TextBlock Text="Gross Pay Difference:" Style="{StaticResource BodyText}"/>
                                <TextBlock Text="{Binding DifferenceReport.TotalGrossDifference, StringFormat={}{0:C}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,15"/>

                                <TextBlock Text="Net Pay Difference:" Style="{StaticResource BodyText}"/>
                                <TextBlock Text="{Binding DifferenceReport.TotalNetDifference, StringFormat={}{0:C}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,15"/>

                                <TextBlock Text="Tax Difference:" Style="{StaticResource BodyText}"/>
                                <TextBlock Text="{Binding DifferenceReport.TotalTaxDifference, StringFormat={}{0:C}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}"/>
                            </StackPanel>
                        </Border>

                        <DockPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock DockPanel.Dock="Top" Text="Employee Specific Differences" Style="{StaticResource BodyText}" FontWeight="Bold" Margin="0,0,0,5"/>
                            <DataGrid ItemsSource="{Binding DifferenceReport.EmployeeDifferences}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="#181D30" BorderBrush="{DynamicResource BrushBorder}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Emp ID" Binding="{Binding EmployeeId}" Width="60" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding EmployeeName}" Width="120" />
                                    <DataGridTextColumn Header="Gross Diff" Binding="{Binding GrossPayDiff, StringFormat={}{0:C}}" Width="90" />
                                    <DataGridTextColumn Header="Net Diff" Binding="{Binding NetPayDiff, StringFormat={}{0:C}}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TABS 9: REPLAY CONSOLE -->
            <TabItem Header="Replay Console" Width="105" Height="30">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1D243B" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Deterministic Replay Engine" Style="{StaticResource Header2}" Margin="0,0,0,20"/>

                            <TextBlock Text="Target Run ID for Snapshot Replay:" Style="{StaticResource BodyText}" Margin="0,0,0,5" />
                            <TextBox Text="{Binding SelectedRunId}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>

                            <Button Content="Execute Replay Verification" Command="{Binding RunReplayCommand}" Margin="0,20,0,0" Height="35" Style="{StaticResource ModernButton}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#1D243B" CornerRadius="8" Padding="20" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Replay Match Result" Style="{StaticResource Header2}" Margin="0,0,0,15"/>
                            
                            <TextBlock Text="Status:" Style="{StaticResource BodyText}" />
                            <TextBlock Text="{Binding ReplayStatusText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,15"/>

                            <TextBlock Text="Calculated SHA-256 Hash:" Style="{StaticResource BodyText}" />
                            <TextBlock Text="{Binding ReplayCalculatedHash}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}" TextWrapping="Wrap" Margin="0,0,0,15"/>

                            <TextBlock Text="Integrity Check:" Style="{StaticResource BodyText}" />
                            <TextBlock Text="PASS" FontSize="24" FontWeight="Bold" Foreground="LimeGreen" Visibility="{Binding ReplayMatchResult, TargetNullValue=Collapsed}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TABS 10: DIAGNOSTICS -->
            <TabItem Header="Diagnostics" Width="90" Height="30">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1D243B" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Diagnostics Telemetry Metrics" Style="{StaticResource Header2}" Margin="0,0,0,20"/>

                            <TextBlock Text="CPU Usage:" Style="{StaticResource BodyText}" />
                            <TextBlock Text="{Binding CpuUsage, StringFormat={}{0:0.0}%}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,15"/>

                            <TextBlock Text="Memory Usage:" Style="{StaticResource BodyText}" />
                            <TextBlock Text="{Binding MemoryUsageMb, StringFormat={}{0:0} MB}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,15"/>

                            <TextBlock Text="Thread Count:" Style="{StaticResource BodyText}" />
                            <TextBlock Text="{Binding ThreadCount}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#1D243B" CornerRadius="8" Padding="20" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="System Stats" Style="{StaticResource Header2}" Margin="0,0,0,20"/>

                            <TextBlock Text="GC Collections (Gen 0):" Style="{StaticResource BodyText}" />
                            <TextBlock Text="{Binding GcCollections}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,15"/>

                            <TextBlock Text="System Throughput / Latency:" Style="{StaticResource BodyText}" />
                            <TextBlock Text="{Binding SystemThroughput}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            
        </TabControl>
    </Grid>
</UserControl>
