<Application x:Class="FijiPayroll.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FijiPayroll.WPF">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Load the default color theme dictionary first -->
                <ResourceDictionary Source="Styles/Theme.Dark.xaml" />
                <!-- Load the layout/template styles dictionary next -->
                <ResourceDictionary Source="Styles/FluentStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
