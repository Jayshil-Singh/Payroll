<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:FijiPayroll.WPF.ViewModels"
                    xmlns:v="clr-namespace:FijiPayroll.WPF.Views">

    <!-- ViewModel to View Mappings -->
    <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
        <v:DashboardView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:EmployeeViewModel}">
        <v:EmployeeView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PayrollViewModel}">
        <v:PayrollView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:SetupViewModel}">
        <v:SetupView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
        <v:ReportsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:AdminViewModel}">
        <v:AdminView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:LogViewerViewModel}">
        <v:LogViewerView />
    </DataTemplate>

    <!-- Fonts -->
    <FontFamily x:Key="FontMain">Segoe UI, Segoe UI Semibold, Arial</FontFamily>

    <!-- Typography Styles -->
    <Style x:Key="Header1" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMain}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
    </Style>

    <Style x:Key="Header2" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMain}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
    </Style>

    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMain}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}" />
    </Style>

    <!-- Modern Rounded Button Style -->
    <Style x:Key="ModernButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="FontFamily" Value="{StaticResource FontMain}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource BrushAccentHover}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#2A314A" />
                            <Setter Property="Foreground" Value="#626D8A" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
        <Setter Property="Background" Value="#2E3656" />
        <Setter Property="BorderBrush" Value="#3F4972" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3E4872" />
                            <Setter Property="BorderBrush" Value="#4F5B8F" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#1C2133" />
                            <Setter Property="BorderBrush" Value="#252D47" />
                            <Setter Property="Foreground" Value="#525E7E" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sidebar Navigation Item Button Style -->
    <Style x:Key="SidebarNavItem" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontMain}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="GroupName" Value="SidebarNav" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="4,0,0,0"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#171D2F" />
                            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#1B2238" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Global Scrollbar styling to fit the theme dynamically -->
    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false" />
        <Setter Property="Stylus.IsFlicksEnabled" Value="false" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid x:Name="Bg" SnapsToDevicePixels="true">
                        <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Background="{DynamicResource BrushBorder}" Width="6" MinHeight="20" Margin="2,0">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="{x:Type Thumb}">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="3" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
