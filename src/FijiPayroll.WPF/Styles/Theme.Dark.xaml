<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Theme Colors -->
    <Color x:Key="ColorBgDeep">#111625</Color>
    <Color x:Key="ColorBgPanel">#1B2032</Color>
    <Color x:Key="ColorBgSidebar">#0D111A</Color>
    <Color x:Key="ColorBorder">#2E3656</Color>
    <Color x:Key="ColorAccent">#0D99FF</Color>
    <Color x:Key="ColorAccentHover">#3FA9FF</Color>
    <Color x:Key="ColorTextPrimary">#FFFFFF</Color>
    <Color x:Key="ColorTextSecondary">#A0AEC0</Color>
    
    <Color x:Key="ColorAlertGreen">#48BB78</Color>
    <Color x:Key="ColorAlertOrange">#ED8936</Color>
    <Color x:Key="ColorAlertRed">#F56565</Color>

    <!-- Theme Brushes -->
    <SolidColorBrush x:Key="BrushBgDeep" Color="{StaticResource ColorBgDeep}" />
    <SolidColorBrush x:Key="BrushBgPanel" Color="{StaticResource ColorBgPanel}" />
    <SolidColorBrush x:Key="BrushBgSidebar" Color="{StaticResource ColorBgSidebar}" />
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}" />
    <SolidColorBrush x:Key="BrushAccentHover" Color="{StaticResource ColorAccentHover}" />
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}" />
    
    <SolidColorBrush x:Key="BrushAlertGreen" Color="{StaticResource ColorAlertGreen}" />
    <SolidColorBrush x:Key="BrushAlertOrange" Color="{StaticResource ColorAlertOrange}" />
    <SolidColorBrush x:Key="BrushAlertRed" Color="{StaticResource ColorAlertRed}" />

</ResourceDictionary>
