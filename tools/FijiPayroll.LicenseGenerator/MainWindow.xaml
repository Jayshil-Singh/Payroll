<Window x:Class="FijiPayroll.LicenseGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FEPS License Provisioning Tool" 
        Height="720" Width="720"
        WindowStartupLocation="CenterScreen"
        Background="#0B0F19"
        FontFamily="Segoe UI"
        Foreground="#E2E8F0"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Premium Styled TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#121826"/>
            <Setter Property="BorderBrush" Value="#252D42"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,4,0,16"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#38BDF8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="BorderBrush" Value="#38BDF8"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter Property="BorderBrush" Value="#38BDF8"/>
                                <Setter Property="Background" Value="#151C2C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#0EA5E9"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="#0284C7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" Value="#0369A1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="BorderBrush" Value="#475569"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Form Field Label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <!-- DatePicker Custom styling -->
        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Background" Value="#121826"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#252D42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="0,4,0,16"/>
            <Setter Property="Height" Value="34"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Content Panel -->
            <RowDefinition Height="*"/>
            <!-- Status/Feedback Bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER: Logo and Title -->
        <Border Grid.Row="0" Background="#111827" BorderBrush="#1F2937" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <Border Width="40" Height="40" Background="#0F766E" CornerRadius="8" Grid.Column="0">
                    <TextBlock Text="🔑" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                
                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="FIJI PAYROLL LICENSE SYSTEM" Foreground="#F1F5F9" FontWeight="Bold" FontSize="15"/>
                    <TextBlock Text="Enterprise Offline License Generation Utility" Foreground="#64748B" FontSize="11" FontWeight="Medium" Margin="0,1,0,0" />
                </StackPanel>

                <Border Grid.Column="2" Background="#1E293B" CornerRadius="12" Padding="10,4" VerticalAlignment="Center">
                    <TextBlock Text="v1.0.0" Foreground="#06B6D4" FontSize="11" FontWeight="Bold" />
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24">
            <StackPanel>
                <!-- Quick Preset Configs -->
                <TextBlock Style="{StaticResource FieldLabel}" Text="QUICK TEMPLATE PRESETS" Margin="0,0,0,8" />
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Content="Developer Setup (1 Year)" Margin="0,0,6,0" Style="{StaticResource SecondaryButton}" Click="PresetDev_Click"/>
                    <Button Grid.Column="1" Content="Standard Trial (30 Days)" Margin="6,0,6,0" Style="{StaticResource SecondaryButton}" Click="PresetTrial_Click"/>
                    <Button Grid.Column="2" Content="Enterprise (3 Years)" Margin="6,0,0,0" Style="{StaticResource SecondaryButton}" Click="PresetEnterprise_Click"/>
                </Grid>
                
                <!-- Core Configuration Card -->
                <Border Background="#161F30" BorderBrush="#243048" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel>
                        <!-- Company Name -->
                        <TextBlock Style="{StaticResource FieldLabel}" Text="COMPANY/TENANT LEGAL NAME *" />
                        <TextBox x:Name="TxtCompany" Style="{StaticResource ModernTextBox}" ToolTip="Name must match tenant registration legal name exactly." />

                        <!-- Expiry & Hardware Hash -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="EXPIRY DATE *" />
                                <DatePicker x:Name="DateExpiry" Style="{StaticResource ModernDatePicker}" ToolTip="Select the date when this license expires." />
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="HARDWARE FINGERPRINT HASH (Optional)" />
                                <TextBox x:Name="TxtHardwareHash" Style="{StaticResource ModernTextBox}" ToolTip="Leave blank for any-machine installations. Fill to lock to a specific machine." />
                            </StackPanel>
                        </Grid>

                        <!-- Licensed Features -->
                        <TextBlock Style="{StaticResource FieldLabel}" Text="LICENSED FEATURES *" />
                        <Border Background="#121826" BorderBrush="#252D42" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,4,0,4">
                            <StackPanel>
                                <CheckBox x:Name="ChkSelectAll" Content="Select All Features (*)" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,10" Checked="ChkSelectAll_Checked" Unchecked="ChkSelectAll_Unchecked"/>
                                <Border BorderBrush="#252D42" BorderThickness="0,1,0,0" Margin="0,0,0,10" />
                                <WrapPanel>
                                    <CheckBox x:Name="ChkPayroll" Content="Core Payroll" Foreground="#E2E8F0" Margin="0,0,20,8" Checked="FeatureCheckbox_Changed" Unchecked="FeatureCheckbox_Changed"/>
                                    <CheckBox x:Name="ChkReports" Content="Reports Engine" Foreground="#E2E8F0" Margin="0,0,20,8" Checked="FeatureCheckbox_Changed" Unchecked="FeatureCheckbox_Changed"/>
                                    <CheckBox x:Name="ChkEss" Content="Employee Self Service" Foreground="#E2E8F0" Margin="0,0,20,8" Checked="FeatureCheckbox_Changed" Unchecked="FeatureCheckbox_Changed"/>
                                    <CheckBox x:Name="ChkCompliance" Content="Compliance &amp; Tax" Foreground="#E2E8F0" Margin="0,0,20,8" Checked="FeatureCheckbox_Changed" Unchecked="FeatureCheckbox_Changed"/>
                                    <CheckBox x:Name="ChkAudit" Content="Audit Logging" Foreground="#E2E8F0" Margin="0,0,0,8" Checked="FeatureCheckbox_Changed" Unchecked="FeatureCheckbox_Changed"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Compiled Features Preview:" FontSize="10.5" Foreground="#64748B" Margin="2,0,0,4"/>
                        <TextBlock x:Name="TxtFeatureString" Text="*" Foreground="#06B6D4" FontSize="11" FontWeight="Bold" Margin="4,0,0,16"/>

                        <!-- Private Key PEM -->
                        <TextBlock Style="{StaticResource FieldLabel}" Text="PRIVATE KEY PEM FILE PATH (Optional)" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtPrivateKeyPath" Style="{StaticResource ModernTextBox}" Margin="0,4,8,16" ToolTip="Leave empty to use built-in dev certificate private key." />
                            <Button Grid.Column="1" Content="Browse..." Style="{StaticResource SecondaryButton}" Height="34" Width="90" Margin="0,0,0,12" VerticalAlignment="Center" Click="BrowsePrivateKey_Click"/>
                        </Grid>

                        <!-- Output File -->
                        <TextBlock Style="{StaticResource FieldLabel}" Text="OUTPUT FILE PATH *" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtOutputPath" Style="{StaticResource ModernTextBox}" Margin="0,4,8,16" ToolTip="Choose where to save the .fplic license file." />
                            <Button Grid.Column="1" Content="Browse..." Style="{StaticResource SecondaryButton}" Height="34" Width="90" Margin="0,0,0,12" VerticalAlignment="Center" Click="BrowseOutput_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Action Button -->
                <Button Content="Generate RSA Signed License File" Style="{StaticResource ModernButton}" Height="45" FontSize="14" FontWeight="Bold" Margin="0,24,0,0" Background="#0EA5E9" Click="GenerateLicense_Click"/>
            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER: Status Logs/Notification -->
        <Border Grid.Row="2" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Text="Ready to generate license. Ensure required parameters are configured." Foreground="#94A3B8" FontSize="12.5" VerticalAlignment="Center" TextWrapping="Wrap" Grid.Column="0" Margin="0,0,12,0"/>
                <Button Grid.Column="1" Content="Open Output Folder" Style="{StaticResource SecondaryButton}" Height="28" Padding="8,4" FontSize="11" Click="OpenFolder_Click" x:Name="BtnOpenFolder" Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Window>
